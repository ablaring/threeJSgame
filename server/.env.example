# --- Server / network ---
PORT=2567

# --- Solana mint setup ---
# RPC endpoint. Default mainnet is rate-limited; consider Helius/QuickNode/etc
# for production. For "testing on mainnet" the public endpoint is OK for low volume.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta

# Treasury — where SOL payments are sent. The player's Phantom signs SystemProgram.transfer to this address.
SHOP_TREASURY_ADDRESS=BZevoeuuEQrzFneyFmS6ZVwGfpZcXQp78ZHk3rqH4eYY

# Mint authority — the keypair that signs as creator + collection update authority.
# Generated by `npm run setup:collection`. Keep this SECRET. Anyone with this key can mint
# weapon NFTs. Format: base58-encoded 64-byte secret key (Phantom export format).
MINT_AUTHORITY_SECRET=

# Collection NFT — created once by `npm run setup:collection`. All weapon NFTs are
# minted under this collection. Verifying this collection on each mint is what
# guarantees provenance.
COLLECTION_MINT=

# Static metadata host — where the per-weapon JSON + PNG live.
NFT_METADATA_BASE_URL=https://raw.githubusercontent.com/ablaring/threeJSgame/main/public/nft

# --- Optional: clustering ---
# REDIS_URL=redis://localhost:6379
# PUBLIC_ADDRESS=
